<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JPEG-TO-JPG</title>
    <link rel="stylesheet" href="/css/videos.css">
    <link rel="stylesheet" href="/navbar.css">
    <link rel="stylesheet" href="/footer.css">
    <link rel="shortcut icon" href="/images/favicon/favicon.ico" type="image/x-icon">

</head>

<body>


    <section class="navbar">
        {{>navbar}}
    </section>
    <section class="videos-upload-form">
        <div class="videos-form-div">
            <h2 class="videos-heading">Convert Image From <b>.MP4</b> To <b>.MP3</b></h2>
            <div class="image-container">
                <div class="from">
                    <img src="/images/mp4.PNG" alt="">
                </div>
                <div class="arrow">
                    <img src="/images/rightarrow.png" alt="">
                </div>
                <div class="to">
                    <img src="/images/mp3.PNG" alt="">
                </div>
            </div>
            <form action="/mp4tomp3upload" method="POST" class="videos-form" enctype="multipart/form-data">
                <div class="image-div">
                    <label for="video">Upload an image</label>
                    <input type="file" accept=".mp4" name="video" id="video" required>
                </div>
                {{>fileerror}}
                <div>
                    <label for="btn"></label>
                    <button class='btn' id="btn">Convert</button>
                </div>
            </form>
        </div>
    </section>
    <section class="footer">
        {{>footer}}
    </section>


</body>

</html>