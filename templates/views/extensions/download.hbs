<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/download.css">
    <link rel="stylesheet" href="navbar.css">
    <link rel="stylesheet" href="footer.css">
    <link rel="shortcut icon" href="/images/favicon/favicon.ico" type="image/x-icon">

</head>

<body>


    <section class="navbar">
        {{>navbar}}
    </section>
    <section>
        <div class="download-div">
            <div class="file-name">
                <p>File Name is : <b>{{imagename}}</b></p>
                <p>Click Download Button to download image</p>
            </div>
            <form action="/download" method="GET" enctype="multipart/form-data">
                <div>
                    <input type="text" value={{outputpath}} style="display: block;" name="downloadimage" required>
                </div>
                <div class="download-btn-div">
                    <button class="btn-download">Download</button>
                </div>
            </form>
        </div>
    </section>
    <section class="footer">
        {{>footer}}
    </section>


</body>

</html>