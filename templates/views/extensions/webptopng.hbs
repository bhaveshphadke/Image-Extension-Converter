<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WEBP-TO-PNG</title>
    <link rel="stylesheet" href="/css/webptopng.css">
    <link rel="stylesheet" href="/navbar.css">
    <link rel="stylesheet" href="/footer.css">
</head>

<body>


    <section class="navbar">
        {{>navbar}}
    </section>
    <section class="webptopng-upload-form">
        <div class="webptopng-form-div">
            <h2 class="webptopng-heading">Convert Image From <b>.WEBP</b> To <b>.PNG</b></h2>
            <form action="/webptopngupload" method="POST" class="webptopng-form" enctype="multipart/form-data">
                <div class="image-div">
                    <label for="image">Upload an image</label>
                    <input type="file" name="image" id="image">
                </div>
                <div>
                    <label for="btn"></label>
                    <button class='btn' id="btn">Convert</button>
                </div>
            </form>
        </div>
    </section>
    <section class="footer">
        {{>footer}}
    </section>


</body>

</html>